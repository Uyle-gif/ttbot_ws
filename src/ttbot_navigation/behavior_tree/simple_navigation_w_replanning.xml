<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="3" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <RecoveryNode number_of_retries="3" name="NavigateRecovery">
      
      <Sequence>
        <ComputePathToPose goal="{goal}"
                           planner_id="GridBased"
                           path="{path}"/>
                           
        <FollowPath controller_id="FollowPath"
                    path="{path}"/>
      </Sequence>
      
      <ClearEntireCostmap service_name="local_costmap/clear_entirely_local_costmap"/>
      
    </RecoveryNode>
  </BehaviorTree>
  
  <TreeNodesModel>
    <Action ID="ComputePathToPose">
      <input_port name="goal"/>
      <input_port name="planner_id"/>
      <output_port name="path"/>
    </Action>
    <Action ID="FollowPath">
      <input_port name="controller_id"/>
      <input_port name="path"/>
    </Action>
    <Action ID="ClearEntireCostmap">
      <input_port name="service_name"/>
    </Action>
  </TreeNodesModel>
</root>